# URL base da Orbit.Api (inclui o prefixo /api/v1).
NEXT_PUBLIC_API_URL=https://localhost:5001/api/v1

# URL do Hub SignalR (notificações em tempo real).
NEXT_PUBLIC_HUB_URL=https://localhost:5001/hubs/orbit

# Tenant usado quando o host não tem subdomínio (ex.: localhost em dev).
# Em produção o tenant vem do subdomínio: empresaA.orbit.com -> empresaa
NEXT_PUBLIC_DEFAULT_TENANT=default
